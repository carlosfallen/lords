{
    "name": "lords-cf-api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "db:migrate": "wrangler d1 execute lords-crm --file=./migrations/schema.sql",
        "db:migrate:local": "wrangler d1 execute lords-crm --local --file=./migrations/schema.sql",
        "db:seed:local": "wrangler d1 execute lords-crm --local --file=./migrations/seed.sql"
    },
    "dependencies": {
        "hono": "^4.6.0",
        "drizzle-orm": "^0.36.0",
        "jose": "^5.9.0"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20241127.0",
        "wrangler": "^3.93.0",
        "typescript": "^5.6.0",
        "drizzle-kit": "^0.28.0"
    }
}